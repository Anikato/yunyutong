# ============================================
# 云域通 (YunYuTong) 环境变量配置示例
# ============================================
# 
# 复制此文件为 .env 并修改配置:
#   cp env.example .env
#
# ============================================

# ---------- Flask 配置 ----------

# 应用入口
FLASK_APP=run.py

# 环境类型: development (开发) / production (生产)
FLASK_ENV=production

# 调试模式: 0 (关闭) / 1 (开启)
# 警告: 生产环境必须关闭!
FLASK_DEBUG=0

# 开发服务器绑定地址 (仅开发环境)
# FLASK_HOST=127.0.0.1
# FLASK_PORT=5000

# ---------- 安全密钥 (必须修改!) ----------

# Flask Session 密钥 (用于签名 cookie)
# 生成方法: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY='your-secret-key-change-this'

# API Token 加密密钥 (Fernet 密钥)
# 生成方法: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY='your-fernet-key-change-this'

# ---------- 数据库配置 ----------

# 默认使用 SQLite (无需配置)
# DATABASE_URL=sqlite:///yunyutong.db

# PostgreSQL 示例:
# DATABASE_URL=postgresql://username:password@localhost:5432/yunyutong

# MySQL 示例:
# DATABASE_URL=mysql+pymysql://username:password@localhost:3306/yunyutong

# ---------- 日志配置 (可选) ----------

# LOG_LEVEL=INFO
# LOG_FILE=logs/yunyutong.log
