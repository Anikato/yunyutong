# ============================================================
# 云域通 Nginx location 配置示例
# 将此块放入你的 server {} 内
# ============================================================

location / {
    proxy_pass http://127.0.0.1:4949;
    proxy_http_version 1.1;

    # ── 转发真实客户端信息（防爆破 IP 识别依赖此项）──────────
    proxy_set_header Host               $host;
    proxy_set_header X-Real-IP          $remote_addr;          # 真实 IP，不可被客户端伪造
    proxy_set_header X-Forwarded-For    $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto  $scheme;               # http / https

    # ── 超时设置 ──────────────────────────────────────────────
    proxy_connect_timeout  60s;
    proxy_send_timeout     120s;   # DNS 同步可能稍慢，留点余量
    proxy_read_timeout     120s;

    # ── 缓冲优化 ──────────────────────────────────────────────
    proxy_buffering        on;
    proxy_buffer_size      8k;
    proxy_buffers          8 16k;

    # ── 安全响应头 ────────────────────────────────────────────
    add_header X-Frame-Options         "SAMEORIGIN"           always;
    add_header X-Content-Type-Options  "nosniff"              always;
    add_header Referrer-Policy         "strict-origin"        always;

    # 如果已开启 HTTPS，取消注释以下一行：
    # add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;
}

# ── 静态资源缓存（可选，减少应用服务器压力）────────────────────
location /static/ {
    proxy_pass http://127.0.0.1:4949/static/;

    proxy_set_header Host $host;

    # 浏览器缓存 7 天，CSS/JS/图片不常变
    expires            7d;
    add_header Cache-Control "public, no-transform";
    access_log         off;
}
