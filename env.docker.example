# ============================================================
# 云域通 Docker 部署配置
# 使用方法：cp env.docker.example .env，然后填入真实密钥
# ============================================================

# ── Flask Session 签名密钥（必须修改，否则 cookie 不安全）──
# 生成命令：python3 -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=替换为你生成的随机字符串

# ── API Token 加密密钥（必须修改，修改后旧数据将无法解密）──
# 生成命令：python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=替换为你生成的Fernet密钥

# ── Gunicorn 工作进程数（可选，默认2）──
# 建议设置为 CPU核数 × 2，内存不足时保持 2
# GUNICORN_WORKERS=2

# ── 注意 ──────────────────────────────────────────────────
# DATABASE_URL 已在 docker-compose.yml 中统一配置，无需在此设置
# FLASK_ENV / FLASK_DEBUG 也已在 docker-compose.yml 中设置
