# ==========================================
# 方案 3: 使用 TCP 端口 (简单配置)
# ==========================================
# 
# 如果 Gunicorn 监听 TCP 端口而非 Unix Socket:
#
# upstream yunyutong {
#     server 127.0.0.1:8000;
# }
#
# 其余配置相同

