# ============================================
# 云域通 (YunYuTong) Nginx 反向代理配置示例
# ============================================
#
# 安装方法:
#   1. 修改下面的配置 (域名、路径等)
#   2. 复制到 Nginx 配置目录:
#      sudo cp nginx.conf.example /etc/nginx/sites-available/yunyutong
#   3. 创建符号链接启用站点:
#      sudo ln -s /etc/nginx/sites-available/yunyutong /etc/nginx/sites-enabled/
#   4. 测试配置:
#      sudo nginx -t
#   5. 重启 Nginx:
#      sudo systemctl reload nginx
#
# ============================================

# ==========================================
# 默认配置: 使用 TCP 端口 (推荐)
# ==========================================

upstream yunyutong {
    # TCP 端口连接 (与 systemd 服务配置对应)
    server 127.0.0.1:8000;
    
    # 可选: 配置健康检查
    keepalive 32;
}

server {
    listen 80;
    listen [::]:80;
    
    # ========== 请修改域名 ==========
    server_name dns.example.com;
    
    # 重定向 HTTP 到 HTTPS (配置 SSL 后取消注释)
    # return 301 https://$server_name$request_uri;
    
    # 日志
    access_log /var/log/nginx/yunyutong_access.log;
    error_log /var/log/nginx/yunyutong_error.log;
    
    # 客户端上传大小限制
    client_max_body_size 10M;
    
    # 静态文件 (直接由 Nginx 处理，提高性能)
    # ========== 请修改路径 ==========
    location /static/ {
        alias /data/yunyutong/app/static/;
        expires 30d;
        add_header Cache-Control "public, immutable";
        
        # 开启 gzip 压缩
        gzip_static on;
    }
    
    # 动态请求转发到 Gunicorn
    location / {
        proxy_pass http://yunyutong;
        proxy_redirect off;
        
        # 传递客户端信息
        proxy_set_header Host $http_host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        
        # 连接优化
        proxy_http_version 1.1;
        proxy_set_header Connection "";
        
        # 超时设置
        proxy_connect_timeout 60s;
        proxy_send_timeout 60s;
        proxy_read_timeout 60s;
        
        # 缓冲设置
        proxy_buffering on;
        proxy_buffer_size 4k;
        proxy_buffers 8 4k;
    }
}

# ==========================================
# HTTPS 配置 (推荐生产环境)
# ==========================================
# 
# 使用 Certbot 自动配置 SSL:
