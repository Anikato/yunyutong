# ==========================================
# 备选方案: 使用 Unix Socket
# ==========================================
# 
# 如果需要使用 Unix Socket，修改 upstream 配置:
#
# upstream yunyutong {
#     server unix:/data/yunyutong/yunyutong.sock fail_timeout=0;
# }
#
# 同时修改 deploy.sh 中的 Gunicorn 配置:
#   --bind unix:/data/yunyutong/yunyutong.sock
#   -m 007
#
# 注意: Unix Socket 需要正确设置文件权限

